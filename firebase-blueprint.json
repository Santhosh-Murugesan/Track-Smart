{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with password hash for server-side auth",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "passwordHash": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "passwordHash", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An expense item tracked by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "category", "description", "date", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user document profiles"
    },
    "expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of expense items across all users"
    }
  }
}
